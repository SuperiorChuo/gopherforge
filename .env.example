# Copy to .env before running docker compose if you need local overrides.

TZ=Asia/Shanghai
APP_ENV=development
# Production enables strict config validation. Replace all local defaults below before setting APP_ENV=production.

# Host ports
FRONTEND_PORT=3000
BACKEND_PORT=8081
MYSQL_PORT=3306
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003

# MySQL
MYSQL_DATABASE=go_admin_kit
# Development default only; production must use a strong non-default password.
MYSQL_ROOT_PASSWORD=123456
DB_USER=root

# Redis
# Development can leave this empty; production must set a strong password.
REDIS_PASSWORD=
REDIS_DB=0

# Backend
# Development default only; production requires at least 32 non-placeholder characters.
JWT_SECRET=local-dev-secret-change-me-32-chars
JWT_REFRESH_TOKEN_ROTATION=true
UPLOAD_STORAGE_TYPE=local
UPLOAD_LOCAL_PATH=./uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
UPLOAD_LOCAL_URL_PREFIX=/uploads
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=
UPLOAD_S3_ACCESS_KEY=
UPLOAD_S3_SECRET_KEY=
UPLOAD_S3_USE_SSL=true
UPLOAD_MINIO_ENDPOINT=go-admin-kit-minio:9000
UPLOAD_MINIO_BUCKET=go-admin-kit
UPLOAD_MINIO_REGION=us-east-1
UPLOAD_MINIO_ACCESS_KEY=minioadmin
UPLOAD_MINIO_SECRET_KEY=minioadmin
UPLOAD_MINIO_USE_SSL=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
CORS_ALLOW_CREDENTIALS=true
METRICS_ENABLED=true

# Optional storage profile
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Optional monitoring profile
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
