# Copy to .env before running docker compose if you need local overrides.

TZ=Asia/Shanghai
APP_ENV=development
# Production enables strict config validation. Replace all local defaults below before setting APP_ENV=production.

# Host ports
GATEWAY_PORT=8000
FRONTEND_PORT=3000
# Business services trust gateway-injected X-Auth-* headers, so their host
# ports bind loopback only by default. Set SERVICES_BIND_IP=0.0.0.0 ONLY if
# you understand this exposes header-forgeable endpoints to the network.
#SERVICES_BIND_IP=127.0.0.1
BACKEND_PORT=8081
AUTH_SERVICE_PORT=8082
IDENTITY_SERVICE_PORT=8083
SYSTEM_SERVICE_PORT=8084
AUDIT_SERVICE_PORT=8085
FILE_SERVICE_PORT=8086
AI_SERVICE_PORT=8087
CC_SERVICE_PORT=8089
CRM_SERVICE_PORT=8091
MP_SERVICE_PORT=8092
NATS_PORT=4222
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003

# PostgreSQL
POSTGRES_DB=go_admin_kit
# Development default only; production must use a strong non-default password.
POSTGRES_PASSWORD=123456
POSTGRES_USER=postgres
DB_SSLMODE=disable

# Redis
# Development can leave this empty; production must set a strong password.
REDIS_PASSWORD=
REDIS_DB=0

# AI service. Provider-agnostic: point AI_BASE_URL at any OpenAI-compatible
# endpoint (DeepSeek/Qwen/Ollama) or set AI_PROVIDER=anthropic. Empty
# AI_API_KEY leaves the service running with AI endpoints returning 503.
#AI_PROVIDER=openai
#AI_BASE_URL=
#AI_API_KEY=
#AI_CHAT_MODEL=
#AI_EMBED_MODEL=

# NATS (auth events). Compose wires services to nats://go-admin-kit-nats:4222;
# for bare-metal runs set NATS_URL=nats://localhost:4222. Empty disables events.
#NATS_URL=

# Docker socket mounted into the Traefik gateway for service discovery.
# Docker Desktop for Mac: use /var/run/docker.sock.raw (the plain socket
# denies in-container access). Linux: keep the default.
#DOCKER_SOCK=/var/run/docker.sock

# Backend
# Development default only; production requires at least 32 non-placeholder characters.
JWT_SECRET=local-dev-secret-change-me-32-chars
JWT_REFRESH_TOKEN_ROTATION=true
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=5
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/oauth/github/callback
WECHAT_OAUTH_ENABLED=false
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=
WECHAT_REDIRECT_URI=http://localhost:8000/api/v1/oauth/wechat/callback
UPLOAD_STORAGE_TYPE=local
UPLOAD_LOCAL_PATH=./uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
UPLOAD_LOCAL_URL_PREFIX=/uploads
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=
UPLOAD_S3_ACCESS_KEY=
UPLOAD_S3_SECRET_KEY=
UPLOAD_S3_USE_SSL=true
UPLOAD_MINIO_ENDPOINT=go-admin-kit-minio:9000
UPLOAD_MINIO_BUCKET=go-admin-kit
UPLOAD_MINIO_REGION=us-east-1
UPLOAD_MINIO_ACCESS_KEY=minioadmin
UPLOAD_MINIO_SECRET_KEY=minioadmin
UPLOAD_MINIO_USE_SSL=false
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
CORS_ALLOW_CREDENTIALS=true
METRICS_ENABLED=true

# Optional email notifications
EMAIL_NOTIFICATION_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=25
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SENDER=
EMAIL_ALERT_RECEIVER=
EMAIL_ALERT_RECEIVERS=
EMAIL_SUBJECT_TEMPLATE=
EMAIL_BODY_TEMPLATE=
EMAIL_USE_TLS=false
EMAIL_START_TLS=false

# Optional storage profile
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Optional monitoring profile
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
