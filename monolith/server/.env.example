CONFIG_FILE=./configs/config.yaml
APP_ENV=development
APP_PORT=8081

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=go_admin_kit

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_TOKEN_ROTATION=true
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8081/api/v1/oauth/github/callback
WECHAT_OAUTH_ENABLED=false
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=
WECHAT_REDIRECT_URI=http://localhost:8081/api/v1/oauth/wechat/callback

UPLOAD_STORAGE_TYPE=local
UPLOAD_LOCAL_PATH=./uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
UPLOAD_LOCAL_URL_PREFIX=/uploads
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=
UPLOAD_S3_ACCESS_KEY=
UPLOAD_S3_SECRET_KEY=
UPLOAD_S3_USE_SSL=true
UPLOAD_MINIO_ENDPOINT=127.0.0.1:9000
UPLOAD_MINIO_BUCKET=go-admin-kit
UPLOAD_MINIO_REGION=us-east-1
UPLOAD_MINIO_ACCESS_KEY=minioadmin
UPLOAD_MINIO_SECRET_KEY=minioadmin
UPLOAD_MINIO_USE_SSL=false

CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:3002,http://localhost:3002
CORS_ALLOW_CREDENTIALS=true

TRUSTED_PROXIES=127.0.0.1
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=5
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=1
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_LIMIT_ENABLED=true
LOGIN_LIMIT_WINDOW_MINUTES=15
LOGIN_LIMIT_MAX_FAILURES=5
LOGIN_LIMIT_LOCK_MINUTES=30
DEFAULT_ADMIN_WARN_DEFAULT_PASSWORD=true
DEFAULT_ADMIN_FORCE_CHANGE_PASSWORD=false
DEFAULT_ADMIN_USERNAME=admin

EMAIL_NOTIFICATION_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=25
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SENDER=
EMAIL_ALERT_RECEIVER=
EMAIL_ALERT_RECEIVERS=
EMAIL_SUBJECT_TEMPLATE=
EMAIL_BODY_TEMPLATE=
EMAIL_USE_TLS=false
EMAIL_START_TLS=false

REQUEST_ID_HEADER=X-Request-ID
METRICS_ENABLED=true
TRACING_ENABLED=false
TRACING_SERVICE_NAME=go-admin-kit-api
TRACING_ENVIRONMENT=development
TRACING_OTLP_ENDPOINT=127.0.0.1:4317
TRACING_SAMPLE_RATIO=1.0
