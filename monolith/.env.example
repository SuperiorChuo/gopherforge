# 单体版环境变量（与 microservices 独立，勿混用）
# cp .env.example .env

POSTGRES_PASSWORD=123456
POSTGRES_DB=go_admin_kit_mono
POSTGRES_USER=postgres
# 宿主机端口（与微服务默认 5432/6379/3000/8081 错开）
POSTGRES_PORT=5433
REDIS_PORT=6380
BACKEND_PORT=18081
FRONTEND_PORT=3001

DB_SSLMODE=disable
JWT_SECRET=local-dev-secret-change-me-32-chars
TZ=Asia/Shanghai
APP_ENV=development
