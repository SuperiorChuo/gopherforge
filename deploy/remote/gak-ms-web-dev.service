[Unit]
Description=go-admin-kit microservices web dev (vite HMR)
After=network.target

[Service]
WorkingDirectory=/www/go-admin-kit/src/microservices/web
Environment=PATH=/usr/local/node22/bin:/usr/local/node/bin:/usr/local/bin:/usr/bin:/bin
# 代理到 monorepo 微服务 Traefik 网关
Environment=VITE_DEV_API_TARGET=http://127.0.0.1:18100
ExecStart=/usr/local/bin/pnpm run dev:lan
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
